generator client {
  provider = "prisma-client"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

model Category {
  id     String  @id @default(cuid())
  name   String
  slug   String  @unique
  order  Int
  chairs Chair[]
}

model Chair {
  id          String       @id @default(cuid())
  name        String
  price       String
  imageUrl    String
  description String
  details     String
  order       Int
  isVisible   Boolean      @default(true)
  status      String       @default("")
  sku         String?
  categoryId  String?
  category    Category?    @relation(fields: [categoryId], references: [id])
  createdAt   DateTime     @default(now())
  updatedAt   DateTime     @updatedAt
  clicks      ChairClick[]
}

model CatalogView {
  id        String   @id @default(cuid())
  ip        String
  device    String
  userAgent String   @default("")
  token     String?
  timestamp DateTime @default(now())
}

model ChairClick {
  id        String   @id @default(cuid())
  chairId   String
  chair     Chair    @relation(fields: [chairId], references: [id], onDelete: Cascade)
  token     String?
  type      String   @default("click")
  timestamp DateTime @default(now())
}

model Customer {
  id        Int            @id @default(autoincrement())
  name      String
  phone     String
  createdAt DateTime       @default(now())
  links         CampaignLink[]
  campaignLinks CampaignSendLink[]
}

model CampaignLink {
  id         Int      @id @default(autoincrement())
  customerId Int
  token      String   @unique
  sentAt     DateTime @default(now())
  customer   Customer @relation(fields: [customerId], references: [id], onDelete: Cascade)
}

model Campaign {
  id              Int                @id @default(autoincrement())
  title           String
  description     String
  images          String             @default("[]")
  originalPrice   String
  salePrice       String
  whatsappMessage String
  isOutOfStock    Boolean            @default(false)
  expiresAt       DateTime?
  isActive        Boolean            @default(true)
  createdAt       DateTime           @default(now())
  updatedAt       DateTime           @updatedAt
  links           CampaignSendLink[]
}

model CampaignSendLink {
  id         Int           @id @default(autoincrement())
  campaignId Int
  customerId Int
  token      String        @unique @default(cuid())
  sentAt     DateTime      @default(now())
  campaign   Campaign      @relation(fields: [campaignId], references: [id], onDelete: Cascade)
  customer   Customer      @relation(fields: [customerId], references: [id], onDelete: Cascade)
  views      CampaignView[]
}

model CampaignView {
  id        Int               @id @default(autoincrement())
  linkId    Int?
  ip        String?
  device    String?
  userAgent String?
  token     String?
  timestamp DateTime          @default(now())
  link      CampaignSendLink? @relation(fields: [linkId], references: [id], onDelete: SetNull)
}
